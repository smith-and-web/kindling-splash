---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import { APP_VERSION, DOWNLOADS } from '../../data/downloads';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Kindling Writer",
  "description": "Free open-source fiction writing software that keeps your outline visible while you draft. Import from Plottr, Scrivener, yWriter, or Obsidian.",
  "url": "https://kindlingwriter.com/",
  "applicationCategory": "DesktopApplication",
  "operatingSystem": "Windows, macOS, Linux",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "downloadUrl": "https://kindlingwriter.com/download/",
  "screenshot": "https://kindlingwriter.com/og-image.png",
  "softwareVersion": APP_VERSION,
  "license": "https://opensource.org/licenses/MIT",
  "author": {
    "@type": "Organization",
    "name": "Kindling",
    "url": "https://kindlingwriter.com"
  }
};

const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is Kindling available on mobile?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Kindling is currently a desktop app for macOS, Windows, and Linux. A mobile version is not available yet."
      }
    },
    {
      "@type": "Question",
      "name": "Is Kindling free?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Kindling is completely free and open source under the MIT license. No account, subscription, or payment required."
      }
    },
    {
      "@type": "Question",
      "name": "What are the system requirements?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "macOS 12 or later, Windows 10 or later, or x86_64 Linux. Approximately 50 MB disk space. No internet connection required after download."
      }
    }
  ]
};

const platforms = Object.entries(DOWNLOADS) as [string, typeof DOWNLOADS[keyof typeof DOWNLOADS]][];
---

<MarketingLayout
  title="Download Kindling — Free Fiction Writing App for Mac, Windows & Linux"
  description={`Download the Kindling app for macOS, Windows, or Linux. Free, open-source fiction writing software — no account required, works offline. Import outlines from Plottr, Scrivener, yWriter, or Obsidian.`}
  downloadContext="download_page"
  structuredData={structuredData}
>

  <script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />

  <!-- ===== Hero ===== -->
  <section class="page-hero">
    <h1>Download Kindling</h1>
    <span class="version-badge">v{APP_VERSION}</span>
    <p class="page-hero-subtext">The free fiction writing app for plotters and pantsers. Open source. No account required.</p>

    <!-- Download Cards -->
    <div class="download-cards">
      {platforms.map(([key, platform]) => (
        <a
          href={platform.url}
          class="download-card-large"
          data-platform={key}
          onclick={`event.preventDefault();trackDownload('${key}','${platform.url}')`}
        >
          <span class="recommended-badge">Recommended for your OS</span>
          {key === 'mac' && (
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
            </svg>
          )}
          {key === 'windows' && (
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/>
            </svg>
          )}
          {key === 'linux' && (
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a.424.424 0 00-.11.135c-.26.268-.45.6-.663.839-.199.199-.485.267-.797.4-.313.136-.658.269-.864.68-.09.189-.136.394-.132.602 0 .199.027.4.055.536.058.399.116.728.04.97-.249.68-.28 1.145-.106 1.484.174.334.535.47.94.601.81.2 1.91.135 2.774.6.926.466 1.866.67 2.616.47.526-.116.97-.464 1.208-.946.587-.003 1.23-.269 2.26-.334.699-.058 1.574.267 2.577.2.025.134.063.198.114.333l.003.003c.391.778 1.113 1.132 1.884 1.071.771-.06 1.592-.536 2.257-1.306.631-.765 1.683-1.084 2.378-1.503.348-.199.629-.469.649-.853.023-.4-.2-.811-.714-1.376v-.097l-.003-.003c-.17-.2-.25-.535-.338-.926-.085-.401-.182-.786-.492-1.046h-.003c-.059-.054-.123-.067-.188-.135a.357.357 0 00-.19-.064c.431-1.278.264-2.55-.173-3.694-.533-1.41-1.465-2.638-2.175-3.483-.796-1.005-1.576-1.957-1.56-3.368.026-2.152.236-6.133-3.544-6.139zm.529 3.405h.013c.213 0 .396.062.584.198.19.135.33.332.438.533.105.259.158.459.166.724 0-.02.006-.04.006-.06v.105a.086.086 0 01-.004-.021l-.004-.024a1.807 1.807 0 01-.15.706.953.953 0 01-.213.335.71.71 0 00-.088-.042c-.104-.045-.198-.064-.284-.133a1.312 1.312 0 00-.22-.066c.05-.06.146-.133.183-.198.053-.128.082-.264.088-.402v-.02a1.21 1.21 0 00-.061-.4c-.045-.134-.101-.2-.183-.333-.084-.066-.167-.132-.267-.132h-.016c-.093 0-.176.03-.262.132a.8.8 0 00-.205.334 1.18 1.18 0 00-.09.4v.019c.002.089.008.179.02.267-.193-.067-.438-.135-.607-.202a1.635 1.635 0 01-.018-.2v-.02a1.772 1.772 0 01.15-.768c.082-.22.232-.406.43-.534a.985.985 0 01.594-.2z"/>
            </svg>
          )}
          <span class="label">{platform.label}</span>
          <span class="subtext">{platform.note} — {platform.format}</span>
          <span class="size-text">{platform.size}</span>
        </a>
      ))}
    </div>

    <p class="download-note">All downloads from <a href="https://github.com/smith-and-web/kindling/releases" target="_blank" rel="noopener">GitHub Releases</a></p>
  </section>

  <!-- ===== Trust: What You're Downloading ===== -->
  <section class="content-section">
    <h2>What you're downloading</h2>
    <div class="about-download-card">
      <table class="about-download-table">
        <tr><td>Software</td><td>Kindling v{APP_VERSION}</td></tr>
        <tr><td>Type</td><td>Desktop application</td></tr>
        <tr><td>Size</td><td>~10 MB</td></tr>
        <tr><td>License</td><td>MIT License (free and open source)</td></tr>
        <tr><td>Platforms</td><td>macOS 12+, Windows 10+, Linux</td></tr>
        <tr><td>Source code</td><td><a href="https://github.com/smith-and-web/kindling" target="_blank" rel="noopener">View on GitHub</a></td></tr>
      </table>
    </div>

    <!-- Trust Callouts -->
    <div class="trust-callouts">
      <div class="trust-callout">
        <span class="trust-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </span>
        <div>
          <strong>No background services</strong>
          <p>Single desktop app. No browser extensions, toolbars, startup items, or registry changes.</p>
        </div>
      </div>
      <div class="trust-callout">
        <span class="trust-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
        </span>
        <div>
          <strong>No data collected</strong>
          <p>The Kindling app does not collect, transmit, or store personal data. All files stay on your computer.</p>
        </div>
      </div>
      <div class="trust-callout">
        <span class="trust-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        </span>
        <div>
          <strong>Source viewable</strong>
          <p>MIT-licensed open source. <a href="https://github.com/smith-and-web/kindling" target="_blank" rel="noopener">Browse the code on GitHub.</a></p>
        </div>
      </div>
      <div class="trust-callout">
        <span class="trust-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
        </span>
        <div>
          <strong>Fully uninstallable</strong>
          <p>Remove Kindling completely at any time. Your project files are never deleted. <a href="#uninstall">See instructions.</a></p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Quick Start ===== -->
  <section class="content-section alt">
    <h2>Get writing in 60 seconds</h2>
    <ol class="steps-list">
      <li><span class="step-num">1</span> Download and install Kindling</li>
      <li><span class="step-num">2</span> Click "Import Project" and select your Plottr, yWriter, or Markdown file</li>
      <li><span class="step-num">3</span> Choose a scene — your beats appear as expandable prompts</li>
      <li><span class="step-num">4</span> Start writing</li>
    </ol>
  </section>

  <!-- ===== System Requirements (collapsible) ===== -->
  <section class="content-section">
    <details class="collapsible-section" open>
      <summary><h2>System requirements</h2></summary>
      <ul class="sysreq-list">
        {platforms.map(([, platform]) => (
          <li>{platform.sysReq}</li>
        ))}
        <li>~50 MB disk space</li>
        <li>No internet connection required after download</li>
      </ul>
    </details>
  </section>

  <!-- ===== Uninstall Instructions (collapsible) ===== -->
  <section class="content-section alt" id="uninstall">
    <details class="collapsible-section">
      <summary><h2>How to uninstall Kindling</h2></summary>
      <p>Kindling can be completely removed from your computer at any time. Your project files are not deleted when you uninstall Kindling — they remain wherever you saved them.</p>

      <div class="uninstall-platform">
        <h4>macOS</h4>
        <ol>
          <li>Open Finder and go to the Applications folder.</li>
          <li>Drag <strong>Kindling</strong> to the Trash (or right-click &rarr; Move to Trash).</li>
          <li>Empty the Trash.</li>
        </ol>
        <p>Kindling does not install any background services, launch agents, or system extensions. To remove application data (preferences, not project files), delete <code>~/Library/Application Support/com.kindlingwriter.app/</code> if present.</p>
      </div>

      <div class="uninstall-platform">
        <h4>Windows</h4>
        <ol>
          <li>Open <strong>Settings</strong> &rarr; <strong>Apps</strong> &rarr; <strong>Installed apps</strong> (or <strong>Apps &amp; features</strong> on Windows 10).</li>
          <li>Search for <strong>Kindling</strong>.</li>
          <li>Click <strong>Uninstall</strong> and follow the prompts.</li>
        </ol>
        <p>Alternatively, use Control Panel: <strong>Programs and Features</strong> &rarr; select Kindling &rarr; <strong>Uninstall</strong>. Kindling does not install background services or startup items. To remove application data: delete <code>%APPDATA%\com.kindlingwriter.app\</code> if present.</p>
      </div>

      <div class="uninstall-platform">
        <h4>Linux (AppImage)</h4>
        <ol>
          <li>Delete the Kindling AppImage file (wherever you saved it).</li>
          <li>If you created a desktop entry, remove <code>~/.local/share/applications/kindling.desktop</code>.</li>
        </ol>
        <p>To remove application data: delete <code>~/.config/com.kindlingwriter.app/</code> or <code>~/.local/share/com.kindlingwriter.app/</code> if present.</p>
      </div>
    </details>
  </section>

  <!-- ===== Legal Links ===== -->
  <section class="content-section">
    <p class="download-legal-links">By downloading Kindling, you agree to our <a href="/terms/">Terms of Service</a> and <a href="/privacy/">Privacy Policy</a>. Kindling is released under the <a href="https://opensource.org/licenses/MIT" target="_blank" rel="noopener">MIT License</a>. <a href="/code-signing-policy/">Code Signing Policy</a></p>
  </section>

  <!-- ===== CTA ===== -->
  <section class="cta-section">
    <p><a href="https://github.com/smith-and-web/kindling" target="_blank" rel="noopener">View source on GitHub</a> &middot; <a href="/features/">See all features &rarr;</a></p>
    <div class="signup-container" style="max-width: 480px; margin: 24px auto 0;">
      <h2 style="font-size: 18px;">Get notified about updates</h2>
      <form class="signup-form" action="https://app.kit.com/forms/8996985/subscriptions" method="post" target="_blank">
        <input type="email" name="email_address" placeholder="your@email.com" required>
        <button type="submit">Subscribe</button>
      </form>
    </div>
  </section>

</MarketingLayout>

<style>
  /* ===== Version Badge ===== */
  .version-badge {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    color: var(--ember-orange);
    background: rgba(232, 90, 27, 0.15);
    border: 1px solid rgba(232, 90, 27, 0.3);
    padding: 4px 10px;
    border-radius: 100px;
    margin-bottom: 16px;
  }

  /* ===== Recommended Badge ===== */
  .recommended-badge {
    display: none;
    font-size: 11px;
    font-weight: 600;
    color: var(--ember-orange);
    background: rgba(232, 90, 27, 0.15);
    border: 1px solid rgba(232, 90, 27, 0.3);
    padding: 2px 8px;
    border-radius: 100px;
    margin-bottom: 8px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .download-card-large.highlight .recommended-badge {
    display: inline-block;
  }

  /* ===== Download Card Size Text ===== */
  .size-text {
    font-size: 12px;
    color: var(--text-secondary);
    margin-top: 4px;
    opacity: 0.7;
  }

  /* ===== Trust Callouts ===== */
  .trust-callouts {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-top: 32px;
  }

  .trust-callout {
    display: flex;
    gap: 12px;
    padding: 16px;
    background: var(--surface);
    border: 1px solid var(--surface-light);
    border-radius: 10px;
  }

  .trust-icon {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(232, 90, 27, 0.1);
    border-radius: 8px;
    color: var(--ember-orange);
  }

  .trust-callout strong {
    display: block;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 4px;
    color: var(--text-primary);
  }

  .trust-callout p {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  .trust-callout a {
    color: var(--ember-orange);
    text-decoration: none;
  }

  .trust-callout a:hover {
    text-decoration: underline;
  }

  /* ===== Collapsible Sections ===== */
  .collapsible-section {
    border: none;
  }

  .collapsible-section summary {
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .collapsible-section summary::-webkit-details-marker {
    display: none;
  }

  .collapsible-section summary::after {
    content: '';
    display: inline-block;
    width: 8px;
    height: 8px;
    border-right: 2px solid var(--text-secondary);
    border-bottom: 2px solid var(--text-secondary);
    transform: rotate(45deg);
    transition: transform 0.2s;
    margin-left: 8px;
    flex-shrink: 0;
  }

  .collapsible-section[open] summary::after {
    transform: rotate(-135deg);
  }

  .collapsible-section summary h2 {
    display: inline;
    margin-bottom: 0;
  }

  .collapsible-section > :not(summary) {
    margin-top: 16px;
  }

  /* ===== Responsive ===== */
  @media (max-width: 640px) {
    .trust-callouts {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline>
  // OS Detection — highlight the detected platform's card
  (function () {
    var platform = (navigator.platform || '').toLowerCase();
    var ua = navigator.userAgent.toLowerCase();
    var detected = null;

    if (platform.includes('mac') || ua.includes('macintosh')) {
      detected = 'mac';
    } else if (platform.includes('win') || ua.includes('windows')) {
      detected = 'windows';
    } else if (platform.includes('linux') || ua.includes('linux')) {
      detected = 'linux';
    }

    if (detected) {
      var card = document.querySelector('[data-platform="' + detected + '"]');
      if (card) {
        card.classList.add('highlight');
      }
    }
  })();

  // Download tracking — standardized event name across all pages.
  // We navigate to the thanks page and trigger the actual file download
  // from there. Doing both from here races Chrome's download pipeline
  // against the main-frame navigation and cancels the download.
  function trackDownload(platform, _downloadUrl) {
    if (typeof gtag === 'function') {
      gtag('event', 'download_click', {
        os_platform: platform,
        cta_location: 'download_page',
        app_version: '1.2.0'
      });
    }
    window.location.href = '/download/thanks/?os=' + platform;
  }
</script>
