---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import { APP_VERSION } from '../../data/downloads';
---

<MarketingLayout
  title="Thanks for Downloading Kindling!"
  description={`You've downloaded Kindling v${APP_VERSION}. Get started with installation tips, a quick-start guide, and join the community.`}
>
  <!-- Hero -->
  <section class="page-hero">
    <h1>Thanks for downloading Kindling!</h1>
    <span class="version-badge">v{APP_VERSION}</span>
    <p class="page-hero-subtext">
      Your download should start automatically. If not, <a href="/download/">go back to the download page</a>.
    </p>
  </section>

  <!-- Installation Tips -->
  <section class="content-section">
    <h2>Installation tips</h2>
    <p>Your OS may show a security prompt the first time you open Kindling. This is normal for open-source software that isn't distributed through an app store.</p>

    <div class="os-tips" id="os-tips">
      <!-- macOS -->
      <div class="os-tip" data-os="mac">
        <h3>macOS</h3>
        <p>macOS Gatekeeper may block Kindling from opening because it's downloaded from the internet.</p>
        <ol>
          <li>Open <strong>Finder</strong> and go to your <strong>Applications</strong> folder.</li>
          <li>Right-click (or Control-click) on <strong>Kindling</strong> and choose <strong>Open</strong>.</li>
          <li>Click <strong>Open</strong> in the dialog that appears.</li>
        </ol>
        <p>You only need to do this once. After the first launch, macOS will remember your choice.</p>
      </div>

      <!-- Windows -->
      <div class="os-tip" data-os="windows">
        <h3>Windows</h3>
        <p>Windows SmartScreen may show a warning because Kindling is new and not yet widely recognized.</p>
        <ol>
          <li>When the SmartScreen dialog appears, click <strong>More info</strong>.</li>
          <li>Click <strong>Run anyway</strong>.</li>
        </ol>
        <p>This is a one-time step. Future launches will open normally.</p>
      </div>

      <!-- Linux -->
      <div class="os-tip" data-os="linux">
        <h3>Linux</h3>
        <p>The AppImage needs to be marked as executable before you can run it.</p>
        <ol>
          <li>Open a terminal and navigate to your Downloads folder.</li>
          <li>Run: <code>chmod +x Kindling_*.AppImage</code></li>
          <li>Double-click the AppImage or run <code>./Kindling_*.AppImage</code></li>
        </ol>
        <p>Alternatively, right-click the file, go to Properties, and enable "Allow executing file as program."</p>
      </div>
    </div>
  </section>

  <!-- Quick Start -->
  <section class="content-section alt">
    <h2>Write your first scene in 5 minutes</h2>
    <ol class="steps-list">
      <li>
        <span class="step-num">1</span>
        <div>
          <strong>Create or import a project</strong>
          <p>Start fresh or import from Plottr, yWriter, Scrivener, or Markdown.</p>
        </div>
      </li>
      <li>
        <span class="step-num">2</span>
        <div>
          <strong>Add your first scene</strong>
          <p>Give it a title and jot down a few beats — short notes about what should happen.</p>
        </div>
      </li>
      <li>
        <span class="step-num">3</span>
        <div>
          <strong>Start drafting</strong>
          <p>Click a beat to expand it and write your prose. Your outline stays visible as you go.</p>
        </div>
      </li>
      <li>
        <span class="step-num">4</span>
        <div>
          <strong>Add characters and locations</strong>
          <p>Tag references so they auto-surface in the side panel while you write.</p>
        </div>
      </li>
    </ol>
  </section>

  <!-- Community CTAs -->
  <section class="content-section">
    <h2>Join the community</h2>
    <div class="community-grid">
      <a href="https://discord.gg/g7bkj4kY8w" class="community-card" target="_blank" rel="noopener">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"/></svg>
        <strong>Discord</strong>
        <p>Chat with other writers, report bugs, and suggest features.</p>
      </a>
      <a href="https://github.com/smith-and-web/kindling" class="community-card" target="_blank" rel="noopener">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        <strong>Star on GitHub</strong>
        <p>Help others discover Kindling. Every star counts.</p>
      </a>
      <a href="/docs/getting-started/" class="community-card">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        <strong>Documentation</strong>
        <p>Guides, keyboard shortcuts, and import/export tips.</p>
      </a>
    </div>
  </section>

  <!-- Email Signup -->
  <section class="cta-section">
    <div class="signup-container" style="max-width: 480px; margin: 0 auto;">
      <h2 style="font-size: 18px;">Get notified about updates</h2>
      <p style="font-size: 15px; color: var(--text-secondary); margin-bottom: 16px;">We'll email you when new versions are released. No spam, unsubscribe anytime.</p>
      <form class="signup-form" action="https://app.kit.com/forms/8996985/subscriptions" method="post" target="_blank">
        <input type="email" name="email_address" placeholder="your@email.com" required>
        <button type="submit">Subscribe</button>
      </form>
    </div>
  </section>
</MarketingLayout>

<style>
  /* Version badge */
  .version-badge {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    color: var(--ember-orange);
    background: rgba(232, 90, 27, 0.15);
    border: 1px solid rgba(232, 90, 27, 0.3);
    padding: 4px 10px;
    border-radius: 100px;
    margin-bottom: 16px;
  }

  /* OS Tips */
  .os-tips {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-top: 24px;
  }

  .os-tip {
    display: none;
    background: var(--surface);
    border: 1px solid var(--surface-light);
    border-radius: 12px;
    padding: 24px 28px;
  }

  .os-tip.visible {
    display: block;
  }

  .os-tip h3 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 12px;
    color: var(--text-primary);
  }

  .os-tip p {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 12px;
  }

  .os-tip p:last-child {
    margin-bottom: 0;
  }

  .os-tip ol {
    padding-left: 24px;
    margin-bottom: 12px;
  }

  .os-tip ol li {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 8px;
  }

  .os-tip code {
    font-family: 'Monaco', 'Menlo', 'Consolas', monospace;
    font-size: 13px;
    background: var(--deep-charcoal);
    padding: 2px 6px;
    border-radius: 4px;
  }

  /* Steps list overrides for richer content */
  .steps-list li {
    align-items: flex-start;
  }

  .steps-list li strong {
    display: block;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 4px;
  }

  .steps-list li p {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  /* Community grid */
  .community-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
    margin-top: 24px;
  }

  .community-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background: var(--surface);
    border: 1px solid var(--surface-light);
    border-radius: 12px;
    padding: 28px 20px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, transform 0.15s;
  }

  .community-card:hover {
    border-color: var(--ember-orange);
    transform: translateY(-2px);
  }

  .community-card svg {
    width: 28px;
    height: 28px;
    color: var(--ember-orange);
    margin-bottom: 12px;
  }

  .community-card strong {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 16px;
    font-weight: 600;
    display: block;
    margin-bottom: 6px;
    color: var(--text-primary);
  }

  .community-card p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }
</style>

<script is:inline>
  // Detect OS from query parameter or user agent
  (function () {
    var params = new URLSearchParams(window.location.search);
    var os = params.get('os');

    if (!os) {
      var platform = (navigator.platform || '').toLowerCase();
      var ua = navigator.userAgent.toLowerCase();
      if (platform.includes('mac') || ua.includes('macintosh')) {
        os = 'mac';
      } else if (platform.includes('win') || ua.includes('windows')) {
        os = 'windows';
      } else if (platform.includes('linux') || ua.includes('linux')) {
        os = 'linux';
      }
    }

    // Show matching OS tip, or all if unknown
    var tips = document.querySelectorAll('.os-tip');
    var matched = false;
    tips.forEach(function (tip) {
      if (os && tip.getAttribute('data-os') === os) {
        tip.classList.add('visible');
        matched = true;
      }
    });

    // If no match, show all
    if (!matched) {
      tips.forEach(function (tip) {
        tip.classList.add('visible');
      });
    }
  })();

  // GA4 download_complete event — standardized schema
  (function () {
    if (typeof gtag === 'function') {
      var params = new URLSearchParams(window.location.search);
      var os = params.get('os') || 'unknown';
      gtag('event', 'download_complete', {
        os_platform: os,
        app_version: '1.2.0'
      });
    }
  })();
</script>
