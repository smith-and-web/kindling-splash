---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime());

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Kindling Blog",
  "description": "News, updates, and writing tips from the Kindling team.",
  "url": "https://kindlingwriter.com/blog/",
  "publisher": {
    "@type": "Organization",
    "name": "Kindling",
    "url": "https://kindlingwriter.com"
  }
};
---

<MarketingLayout
  title="Blog — Kindling Writer"
  description="News, updates, and writing tips from the Kindling team. Follow along as we build free open-source writing software for plotters and pantsers."
  structuredData={structuredData}
>
  <section class="page-hero">
    <h1>Blog</h1>
    <p class="page-hero-subtext">
      News, updates, and writing tips from the Kindling team.
    </p>
  </section>

  <section class="blog-listing">
    <div class="posts-grid">
      {posts.map((post) => {
        const date = new Date(post.data.publishedDate);
        const formatted = date.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        });
        return (
          <a href={`/blog/${post.id}/`} class="post-card">
            <div class="post-card-inner">
              <div class="post-meta">
                {post.data.tags && post.data.tags.length > 0 && (
                  <span class="post-tag">{post.data.tags[0]}</span>
                )}
                <time datetime={post.data.publishedDate}>{formatted}</time>
              </div>
              <h2>{post.data.title}</h2>
              <p class="post-excerpt">{post.data.description}</p>
              <span class="read-more">Read more &rarr;</span>
            </div>
          </a>
        );
      })}
    </div>
  </section>
</MarketingLayout>

<style>
  .blog-listing {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 24px 80px;
  }

  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .post-card {
    display: block;
    text-decoration: none;
    color: inherit;
    background: var(--surface);
    border: 1px solid var(--surface-light);
    border-radius: 12px;
    transition: border-color 0.2s, transform 0.15s;
  }

  .post-card:hover {
    border-color: var(--ember-orange);
    transform: translateY(-2px);
  }

  .post-card-inner {
    padding: 28px 32px;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .post-tag {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ember-orange);
    background: rgba(232, 90, 27, 0.12);
    border: 1px solid rgba(232, 90, 27, 0.25);
    padding: 3px 10px;
    border-radius: 100px;
  }

  .post-meta time {
    font-size: 14px;
    color: var(--text-secondary);
  }

  .post-card h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 22px;
    font-weight: 600;
    margin-bottom: 8px;
    line-height: 1.3;
    color: var(--text-primary);
  }

  .post-excerpt {
    font-size: 16px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 12px;
  }

  .read-more {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--ember-orange);
  }

  @media (max-width: 600px) {
    .post-card-inner {
      padding: 20px;
    }

    .post-card h2 {
      font-size: 19px;
    }
  }
</style>
