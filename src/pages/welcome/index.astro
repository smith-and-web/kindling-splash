          macOS
        </a>
        <a href="https://github.com/smith-and-web/kindling/releases/latest/download/Kindling_1.2.0_x64-setup.exe" class="download-btn secondary" data-platform="windows" onclick="trackDownload('windows')">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/></svg>
          Windows
        </a>
        <a href="https://github.com/smith-and-web/kindling/releases/latest/download/Kindling_1.2.0_amd64.AppImage" class="download-btn secondary" data-platform="linux" onclick="trackDownload('linux')">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a.424.424 0 00-.11.135c-.26.268-.45.6-.663.839-.199.199-.485.267-.797.4-.313.136-.658.269-.864.68-.09.189-.136.394-.132.602 0 .199.027.4.055.536.058.399.116.728.04.97-.249.68-.28 1.145-.106 1.484.174.334.535.47.94.601.81.2 1.91.135 2.774.6.926.466 1.866.67 2.616.47.526-.116.97-.464 1.208-.946.587-.003 1.23-.269 2.26-.334.699-.058 1.574.267 2.577.2.025.134.063.198.114.333l.003.003c.391.778 1.113 1.132 1.884 1.071.771-.06 1.592-.536 2.257-1.306.631-.765 1.683-1.084 2.378-1.503.348-.199.629-.469.649-.853.023-.4-.2-.811-.714-1.376v-.097l-.003-.003c-.17-.2-.25-.535-.338-.926-.085-.401-.182-.786-.492-1.046h-.003c-.059-.054-.123-.067-.188-.135a.357.357 0 00-.19-.064c.431-1.278.264-2.55-.173-3.694-.533-1.41-1.465-2.638-2.175-3.483-.796-1.005-1.576-1.957-1.56-3.368.026-2.152.236-6.133-3.544-6.139zm.529 3.405h.013c.213 0 .396.062.584.198.19.135.33.332.438.533.105.259.158.459.166.724 0-.02.006-.04.006-.06v.105a.086.086 0 01-.004-.021l-.004-.024a1.807 1.807 0 01-.15.706.953.953 0 01-.213.335.71.71 0 00-.088-.042c-.104-.045-.198-.064-.284-.133a1.312 1.312 0 00-.22-.066c.05-.06.146-.133.183-.198.053-.128.082-.264.088-.402v-.02a1.21 1.21 0 00-.061-.4c-.045-.134-.101-.2-.183-.333-.084-.066-.167-.132-.267-.132h-.016c-.093 0-.176.03-.262.132a.8.8 0 00-.205.334 1.18 1.18 0 00-.09.4v.019c.002.089.008.179.02.267-.193-.067-.438-.135-.607-.202a1.635 1.635 0 01-.018-.2v-.02a1.772 1.772 0 01.15-.768c.082-.22.232-.406.43-.534a.985.985 0 01.594-.2zm-2.962.059h.036c.142 0 .27.048.399.135.146.129.264.288.344.465.09.199.14.4.153.667v.004c.007.134.006.2-.002.266v.08c-.03.007-.056.018-.083.024-.152.055-.274.135-.393.2.012-.09.013-.18.003-.267v-.015c-.012-.133-.04-.2-.082-.333a.613.613 0 00-.166-.267.248.248 0 00-.183-.064h-.021c-.071.006-.13.04-.186.132a.552.552 0 00-.12.27.944.944 0 00-.023.33v.015c.012.135.037.2.08.334.046.134.098.2.166.268.01.009.02.018.034.024-.07.057-.117.07-.176.136a.304.304 0 01-.131.068 2.62 2.62 0 01-.275-.402 1.772 1.772 0 01-.155-.667 1.759 1.759 0 01.08-.668 1.43 1.43 0 01.283-.535c.128-.133.26-.2.418-.2zm1.37 1.706c.332 0 .733.065 1.216.399.293.2.523.269 1.052.468h.003c.255.136.405.266.478.399v-.131a.571.571 0 01.016.47c-.123.31-.516.643-1.063.842v.002c-.268.135-.501.333-.775.465-.276.135-.588.292-1.012.267a1.139 1.139 0 01-.448-.067 3.566 3.566 0 01-.322-.198c-.195-.135-.363-.332-.612-.465v-.005h-.005c-.4-.246-.616-.512-.686-.71-.07-.268-.005-.47.193-.6.224-.135.38-.271.483-.336.104-.074.143-.102.176-.131h.002c.186-.133.36-.333.583-.467.097-.067.197-.135.382-.202a.86.86 0 01.34-.068z"/></svg>
          Linux
        </a>
      </div>

      <p class="download-note">
        Need help? See <a href="https://github.com/smith-and-web/kindling/wiki/Installation">installation guide</a>
      </p>
    </div>

    <!-- What to Expect -->
    <div class="expect-section">
      <h3>What to expect from our emails</h3>
      <ul class="expect-list">
        <li>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
          </svg>
          <span>Writing tips and craft advice tailored for plotters</span>
        </li>
        <li>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          <span>New feature announcements and beta updates</span>
        </li>
        <li>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
          <span>Tutorials and workflow guides</span>
        </li>
      </ul>
    </div>


    <p class="back-link"><a href="/">← Back to kindlingwriter.com</a></p>
    </div>
  </main>

  <script is:inline>
    // Track signup completion
    if (typeof gtag === 'function') {
      gtag('event', 'email_signup_confirmed', {
        event_category: 'engagement',
        event_label: 'welcome_page_view'
      });
    }

    // Download tracking — standardized event
    function trackDownload(platform) {
      if (typeof gtag === 'function') {
        gtag('event', 'download_click', {
          os_platform: platform,
          cta_location: 'welcome_page',
          app_version: '1.2.0'
        });
      }
    }
  </script>

</MarketingLayout>

<style>
  /* Page-specific styles only. Base styles in /assets/site.css */

  main.page-main {
    display: flex;
    justify-content: center;
  }

  .container {
    max-width: 560px;
    text-align: center;
  }

  /* Success Icon */
  .success-icon {
    width: 80px;
    height: 80px;
    background: var(--success);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 24px;
  }

  .success-icon svg {
    width: 40px;
    height: 40px;
    color: white;
  }

  /* Header */
  h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(32px, 6vw, 48px);
    font-weight: 600;
    margin-bottom: 12px;
    letter-spacing: -0.02em;
  }

  .subtitle {
    font-size: 18px;
    color: var(--text-secondary);
    margin-bottom: 40px;
    line-height: 1.7;
  }

  /* CTA Card */
  .cta-card {
    background: var(--surface);
    border: 1px solid var(--surface-light);
    border-radius: 16px;
    padding: 32px;
    margin-bottom: 32px;
  }

  .cta-card h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 24px;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .cta-card p {
    font-size: 16px;
    color: var(--text-secondary);
    margin-bottom: 24px;
  }

  /* What to Expect */
  .expect-section {
    text-align: left;
    margin-bottom: 32px;
  }

  .expect-section h3 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 18px;
    font-weight: 500;
    margin-bottom: 16px;
    color: var(--text-secondary);
  }

  .expect-list {
    list-style: none;
  }

  .expect-list li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid var(--surface-light);
  }

  .expect-list li:last-child {
    border-bottom: none;
  }

  .expect-list svg {
    width: 20px;
    height: 20px;
    color: var(--ember-orange);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .expect-list span {
    font-size: 15px;
    color: var(--text-primary);
  }

  /* Social Links */
  .social-section {
    margin-bottom: 32px;
  }

  .social-section p {
    font-size: 14px;
    color: var(--text-secondary);
    margin-bottom: 12px;
  }

  /* Footer */
  .back-link {
    font-size: 14px;
    color: var(--text-secondary);
  }

  .back-link a {
    color: var(--ember-orange);
    text-decoration: none;
  }

  .back-link a:hover {
    text-decoration: underline;
  }
</style>
