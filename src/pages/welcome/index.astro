---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
---

<MarketingLayout title="You're on the list! – Kindling" description="Thanks for signing up! Download Kindling and start writing with your outline visible." downloadContext="from_welcome">

  <main class="page-padding page-main">
    <div class="container">
    <!-- Success Icon -->
    <div class="success-icon">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
    </div>

    <h1>You're on the list!</h1>
    <p class="subtitle">Thanks for signing up. We'll send you writing tips, new feature announcements, and occasional updates.</p>

    <!-- CTA Card -->
    <div class="cta-card">
      <h2>Ready to start writing?</h2>
      <p>Download Kindling and keep your outline visible while you draft.</p>

      <div class="download-buttons">
        <a href="https://github.com/smith-and-web/kindling/releases/latest/download/Kindling_1.2.0_universal.dmg" class="download-btn" data-platform="mac" onclick="trackDownload('mac')">
