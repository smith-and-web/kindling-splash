---
import { Image } from 'astro:assets';
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import { APP_VERSION } from '../../data/downloads';
import scenePanel from '../../assets/scene-panel.png';
import referencesPanel from '../../assets/references-panel.png';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Kindling Writer",
  "description": "Free, open-source fiction writing software that keeps your outline visible while you draft. Built for plotters, pantsers, and every kind of fiction writer.",
  "url": "https://kindlingwriter.com/",
  "applicationCategory": "DesktopApplication",
  "operatingSystem": "Windows, macOS, Linux",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "softwareVersion": APP_VERSION,
  "license": "https://opensource.org/licenses/MIT",
  "downloadUrl": "https://kindlingwriter.com/download/",
  "screenshot": "https://kindlingwriter.com/og-image.png",
  "author": {
    "@type": "Organization",
    "name": "Kindling",
    "url": "https://kindlingwriter.com"
  },
  "featureList": [
    "Rolling Outline Mode — progressive structure for plotters and plantsers",
    "Blank projects — start from scratch without importing",
    "Import outlines from Plottr, yWriter, Obsidian Longform, and Markdown",
    "Expandable scene beats as writing prompts",
    "Beat management — split, merge, reorder, and delete beats",
    "Inline discovery notes to capture ideas mid-writing",
    "Context-aware character and location references",
    "Command palette for quick access to all actions",
    "Export to DOCX, Markdown, and Obsidian Longform",
    "Local-first — all data stays on your computer",
    "Distraction-free writing interface",
    "Automatic updates — never download manually again",
    "Built with Rust and Tauri for fast performance",
    "Session persistence — pick up where you left off",
    "Free and open source under MIT license"
  ]
};

const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What file formats does Kindling support?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Kindling imports from Plottr (.pltr), yWriter (.yw7), Obsidian Longform, and Markdown outlines. It exports to DOCX, Markdown, and Obsidian Longform format. This lets you bring in your existing outline and export finished work to the tools you already use."
      }
    },
    {
      "@type": "Question",
      "name": "Is Kindling open source?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Kindling is fully open source under the MIT license. The complete source code is available on GitHub at https://github.com/smith-and-web/kindling. Anyone can inspect, modify, and redistribute the code."
      }
    },
    {
      "@type": "Question",
      "name": "Does Kindling send data to the cloud?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Kindling is a local-first desktop application. Your projects are stored as SQLite files on your hard drive. Kindling does not require an account, does not phone home, does not collect analytics, and does not upload your manuscripts. Your data never leaves your machine."
      }
    },
    {
      "@type": "Question",
      "name": "What is Kindling built with?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Kindling is built with Rust and Tauri 2.x for the backend, providing fast performance and a small ~10MB application size. The user interface is built with Svelte 5. Project data is stored in SQLite databases. It launches in under a second and uses a fraction of the memory of Electron-based writing tools."
      }
    }
  ]
};
---

<MarketingLayout
  title="Kindling Writer Features — Free Fiction Writing Software for Plotters & Pantsers"
  description="Writing software for plotters and pantsers. Rolling outlines, expandable scene beats, character references, command palette, auto-updates. Free & open source."
  structuredData={structuredData}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />

  <section class="page-hero">
    <h1>Everything you need to go from outline to draft</h1>
    <p class="page-hero-subtext">Whether you outline every beat or discover your story as you write, Kindling gives you a scaffolded writing space — scene beats as expandable prompts, character details at your fingertips, and the flexibility to add structure at your own pace.</p>
    <a href="/download/" class="download-btn">Download Kindling — Free</a>
    <video autoplay loop muted playsinline preload="metadata" poster="/hero-poster.jpg" width="804" height="556" style="margin-top: 32px; max-width: 100%; height: auto; border-radius: 12px;" aria-label="Scaffolded writing view with scene beats expanded">
      <source src="/demo-2.mp4" type="video/mp4">
    </video>
  </section>

  <!-- ===== Primary Features — Bento Grid ===== -->
  <section class="features-section">
    <div class="bento-grid">
      <!-- Row 1: Core writing -->
      <div class="bento-tile fade-in-on-scroll">
        <div class="bento-label">Core Feature</div>
        <h3>Outline-Aware Drafting</h3>
        <p class="bento-problem">Other apps make you flip between your outline and a blank page.</p>
        <p class="bento-solution">Scene beats appear as expandable prompts in your drafting view. Click a beat, write into it. Your outline is the scaffolding for your first draft.</p>
        <Image src={scenePanel} alt="Kindling editor showing scene beats alongside prose" width={560} loading="eager" class="bento-image" />
      </div>

      <div class="bento-tile fade-in-on-scroll">
        <div class="bento-label">Stay in Flow</div>
        <h3>References Panel</h3>
        <p class="bento-problem">Was it green eyes or blue? What was the tavern called?</p>
        <p class="bento-solution">Characters and locations tagged in your scene auto-surface in a side panel. Physical descriptions, key notes, and custom fields — all visible while you write.</p>
        <Image src={referencesPanel} alt="Kindling references panel showing character details" width={560} loading="lazy" class="bento-image" />
      </div>

      <!-- Row 2: Structure -->
      <div class="bento-tile fade-in-on-scroll">
        <div class="bento-label">Your Pace</div>
        <h3>Rolling Outline</h3>
        <p class="bento-problem">Not every scene needs the same level of planning.</p>
        <p class="bento-solution">Three planning states — <strong>Fixed</strong>, <strong>Flexible</strong>, <strong>Undefined</strong> — let you add structure progressively. Start vague, define as you go. The sidebar adapts automatically.</p>
      </div>

      <div class="bento-tile fade-in-on-scroll">
        <div class="bento-label">Full Control</div>
        <h3>Beat Management</h3>
        <p class="bento-problem">Your outline needs to evolve as you write.</p>
        <p class="bento-solution">Delete, reorder, split, and merge beats with drag-and-drop. A beat density indicator shows how detailed each scene is at a glance.</p>
      </div>

      <!-- Row 3: Workflow -->
      <div class="bento-tile fade-in-on-scroll">
        <div class="bento-label">Capture Ideas</div>
        <h3>Discovery Notes</h3>
        <p class="bento-problem">Inspiration doesn't wait for your outline.</p>
        <p class="bento-solution">Press <strong>Cmd+D</strong> to jot a note mid-scene — a subplot idea, a character insight, a thread to weave in later. Promote notes to full beats when you're ready.</p>
      </div>

      <div class="bento-tile fade-in-on-scroll">
        <div class="bento-label">Your Tools</div>
        <h3>Import & Export</h3>
        <p class="bento-problem">Your outline lives in one app, your manuscript in another.</p>
        <p class="bento-solution">Import from Plottr, Scrivener, yWriter, Obsidian, or Markdown. Export to DOCX, Scrivener, Markdown, or EPUB.</p>
        <div class="flow-diagram">
          <div class="flow-node">
            <span class="flow-label">Import</span>
            <span class="flow-formats">Plottr · Scrivener · yWriter · Obsidian · Markdown</span>
          </div>
          <span class="flow-arrow" aria-hidden="true">↓</span>
          <div class="flow-node flow-node-center">
            <span class="flow-label">Kindling</span>
            <span class="flow-formats">Write & edit</span>
          </div>
          <span class="flow-arrow" aria-hidden="true">↓</span>
          <div class="flow-node">
            <span class="flow-label">Export</span>
            <span class="flow-formats">DOCX · Scrivener · Markdown · EPUB</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== v1.2 Features — Bento Grid ===== -->
  <section class="features-section">
    <div class="features-section-header">
      <h2>New in v1.2</h2>
    </div>
    <div class="bento-grid">
      <div class="bento-tile fade-in-on-scroll">
        <div class="bento-label">Write Your Way</div>
        <h3>Full-Page Prose Editing</h3>
        <p class="bento-problem">Beat-by-beat is great for structure. But sometimes you just want to write.</p>
        <p class="bento-solution">Toggle between beat view and a full-page prose editor per scene. Your beats stay available for reference — you get an uninterrupted writing surface without leaving your structure behind.</p>
      </div>

      <div class="bento-tile fade-in-on-scroll">
        <div class="bento-label">Smart Context</div>
        <h3>Reference Auto-Detection</h3>
        <p class="bento-problem">You mentioned a character three paragraphs ago but forgot to link them.</p>
        <p class="bento-solution">A non-AI engine scans your prose for character, location, and item names. Suggestions surface in the References panel — link with one click, or dismiss. No cloud, no magic, just pattern matching.</p>
      </div>

      <div class="bento-tile fade-in-on-scroll">
        <div class="bento-label">Flexible Data</div>
        <h3>Custom Fields & Tags</h3>
        <p class="bento-problem">Plain text notes don't cut it for complex characters and worlds.</p>
        <p class="bento-solution">Define typed fields (text, number, date, select, multi-select) on any reference type. Organise with hierarchical tags up to three levels deep, with colours and a Tag Manager. Use saved filters to find exactly what you need.</p>
      </div>

      <div class="bento-tile fade-in-on-scroll">
        <div class="bento-label">Screenwriters</div>
        <h3>Screenplay Projects & Templates</h3>
        <p class="bento-problem">Novel tools don't speak the language of screenwriting.</p>
        <p class="bento-solution">Create Screenplay projects with slugline input (INT./EXT.), page count estimation (250 words/page), and treatment export (1-page or 5-page DOCX). Pre-built templates: Save the Cat, Hero's Journey, Three-Act, Seven-Point, Snowflake, Story Grid.</p>
      </div>
    </div>
  </section>

  <!-- ===== Secondary Features — Compact Grid ===== -->
  <section class="features-secondary-section">
    <h2>And everything else you'd expect</h2>
    <div class="features-secondary">
      <div class="feature-card">
        <span class="feature-icon">⌨️</span>
        <div>
          <strong>Command palette</strong>
          <p>Press Cmd+K to fuzzy-search every action — import, export, settings, navigation.</p>
        </div>
      </div>
      <div class="feature-card">
        <span class="feature-icon">📄</span>
        <div>
          <strong>Blank projects</strong>
          <p>Start from scratch with File → New Project. No import required.</p>
        </div>
      </div>
      <div class="feature-card">
        <span class="feature-icon">✨</span>
        <div>
          <strong>Distraction-free writing</strong>
          <p>Clean interface. Beats expand only when you need them. No feature overload.</p>
        </div>
      </div>
      <div class="feature-card">
        <span class="feature-icon">🔒</span>
        <div>
          <strong>Local-first & private</strong>
          <p>SQLite on your hard drive. No cloud, no accounts, no data collection. <a href="/open-source/">Open source.</a></p>
        </div>
      </div>
      <div class="feature-card">
        <span class="feature-icon">⚡</span>
        <div>
          <strong>Built with Rust</strong>
          <p>Sub-second launch. Fraction of the memory of Electron apps. ~10 MB download.</p>
        </div>
      </div>
      <div class="feature-card">
        <span class="feature-icon">💾</span>
        <div>
          <strong>Session persistence</strong>
          <p>Cursor position, scroll state, and active scene — all restored when you reopen.</p>
        </div>
      </div>
      <div class="feature-card">
        <span class="feature-icon">🔄</span>
        <div>
          <strong>Automatic updates</strong>
          <p>New versions download silently. A banner appears when ready — click to restart.</p>
        </div>
      </div>
      <div class="feature-card">
        <span class="feature-icon">🌗</span>
        <div>
          <strong>Light & dark themes</strong>
          <p>System preference detection or manual override. Switch from Settings → Appearance.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Bottom CTA ===== -->
  <section class="cta-section">
    <h2>Ready to spark your draft?</h2>
    <p>Free, open source, MIT licensed. <a href="/compare/" style="color: var(--ember-orange);">See how Kindling compares</a> to Scrivener, Plottr, and other writing tools.</p>
    <div class="download-buttons single">
      <a href="/download/" class="download-btn">Download Kindling — Free</a>
    </div>
  </section>
</MarketingLayout>

<style>
  /* Bento grid (shared pattern with homepage) */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .bento-tile {
    background: var(--deep-charcoal);
    border: 1px solid var(--surface-light);
    border-radius: 16px;
    padding: 28px;
    grid-column: span 2;
    overflow: hidden;
  }

  .bento-label {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ember-orange);
    margin-bottom: 8px;
  }

  .bento-tile h3 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .bento-problem {
    font-size: 15px;
    color: var(--text-secondary);
    font-style: italic;
    margin-bottom: 6px;
  }

  .bento-solution {
    font-size: 15px;
    color: var(--text-primary);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .bento-image {
    width: 100%;
    height: auto;
    border-radius: 8px;
    margin-top: 8px;
  }

  /* Features page layout */
  .features-section {
    padding: 56px 24px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .features-section-header {
    text-align: center;
    margin-bottom: 32px;
  }

  .features-section-header h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(24px, 4vw, 32px);
    font-weight: 600;
  }

  .features-secondary-section {
    padding: 56px 24px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .features-secondary-section h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(24px, 4vw, 32px);
    font-weight: 600;
    text-align: center;
    margin-bottom: 32px;
  }

  .features-secondary {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .feature-card {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    background: var(--deep-charcoal);
    border: 1px solid var(--surface-light);
    border-radius: 12px;
    padding: 20px;
  }

  .feature-icon {
    font-size: 24px;
    flex-shrink: 0;
    line-height: 1;
    margin-top: 2px;
  }

  .feature-card strong {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 16px;
    font-weight: 600;
    display: block;
    margin-bottom: 4px;
  }

  .feature-card p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  .feature-card a {
    color: var(--ember-orange);
    text-decoration: none;
  }

  .feature-card a:hover {
    text-decoration: underline;
  }

  /* Flow diagram scoped styles */
  .flow-diagram {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    margin-top: 12px;
  }

  .flow-node {
    background: var(--surface);
    border: 1px solid var(--surface-light);
    border-radius: 10px;
    padding: 10px 16px;
    text-align: center;
    width: 100%;
  }

  .flow-node-center {
    border-color: var(--ember-orange);
  }

  .flow-label {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 13px;
    display: block;
  }

  .flow-formats {
    font-size: 12px;
    color: var(--text-secondary);
  }

  .flow-arrow {
    font-size: 18px;
    color: var(--text-secondary);
    line-height: 1;
  }

  @media (max-width: 768px) {
    .bento-grid {
      grid-template-columns: 1fr;
    }
    .bento-tile {
      grid-column: span 1;
    }
    .features-secondary {
      grid-template-columns: 1fr;
    }
  }
</style>
