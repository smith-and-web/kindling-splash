---
import { Image } from 'astro:assets';
import MarketingLayout from '../layouts/MarketingLayout.astro';
import SmartDownloadButton from '../components/SmartDownloadButton.svelte';
import { APP_VERSION, DOWNLOADS } from '../data/downloads';
import beatWithProse from '../assets/beat-with-prose.png';
import referencesPanel from '../assets/references-panel.png';

// Ember particles — atmospheric sparks rising in the hero. Generated at
// build time; values are randomized per-ember so the swarm feels organic
// rather than clocked. Negative delays stagger the start so all N are
// already animating mid-cycle when the page loads (no initial "fill" gap).
// Three color variants (ember/flame/gold) simulate how real embers shift hue
// as they cool — some particles hotter, some dimmer.
const emberColors = [
  'rgb(232, 90, 27)',   // ember-orange (base)
  'rgb(232, 90, 27)',   // weighted toward base
  'rgb(255, 138, 61)',  // flame — hotter, lighter
  'rgb(255, 184, 77)',  // gold — coolest/brightest
];

const embers = Array.from({ length: 20 }).map(() => {
  const size = 2 + Math.floor(Math.random() * 7); // 2–8px, keep size variance
  // Cluster x around the middle (Gaussian-ish via averaging) so embers look
  // like they're rising from the concentrated fire bed, not scattered edge-to-edge.
  const x = Math.round(((Math.random() + Math.random()) / 2) * 100);
  return {
    x,
    size,
    duration: 6 + Math.floor(Math.random() * 9),  // 6–14s
    delay: -Math.floor(Math.random() * 14),
    sway: -70 + Math.floor(Math.random() * 140),  // −70 to +70
    // Brightness reduced: opacity caps lower, glow scaled smaller
    opacity: (0.22 + Math.random() * 0.45).toFixed(2), // 0.22–0.67
    color: emberColors[Math.floor(Math.random() * emberColors.length)],
    glow: Math.round(size * 1.3 + Math.random() * 4),
  };
});

const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Kindling Writer",
  "description": "Free open-source fiction writing software that keeps your outline visible while you draft. Import from Plottr, Scrivener, yWriter, or Obsidian.",
  "url": "https://kindlingwriter.com/",
  "applicationCategory": "DesktopApplication",
  "operatingSystem": "Windows, macOS, Linux",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "author": {
    "@type": "Organization",
    "name": "Kindling",
    "url": "https://kindlingwriter.com"
  },
  "softwareVersion": APP_VERSION,
  "license": "https://opensource.org/licenses/MIT",
  "downloadUrl": "https://kindlingwriter.com/download/",
  "screenshot": "https://kindlingwriter.com/og-image.png"
};
---

<MarketingLayout
  title="Kindling Writer — Free Fiction Writing Software for Plotters & Pantsers"
  description="Kindling Writer is free fiction writing software that keeps your outline visible while you draft. Import from Plottr, Scrivener, yWriter, or Obsidian. Desktop app for macOS, Windows & Linux."
  structuredData={structuredData}
>
  <!-- Hero typing effect — runs before the hero renders so the final text
       doesn't flash in before the animation takes over. Fires on every load
       and skips only when prefers-reduced-motion is set. SEO-safe: the full
       headline text stays in the DOM inside the .type-text span (the
       typing script only mutates it client-side). -->
  <script is:inline>
    (function () {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      var style = document.createElement('style');
      style.textContent = '.hero h1 .type-text{visibility:hidden}';
      document.head.appendChild(style);

      function run() {
        var h1 = document.querySelector('.hero h1');
        if (!h1) return;
        var textSpan = h1.querySelector('.type-text');
        if (!textSpan) return;

        var full = textSpan.textContent;
        textSpan.textContent = '';
        textSpan.style.visibility = 'visible';
        h1.classList.add('typing');

        var i = 0;
        (function type() {
          if (i >= full.length) {
            h1.classList.add('type-complete');
            return;
          }
          textSpan.textContent += full[i];
          i++;
          var ch = full[i - 1];
          var delay = ch === ' ' ? 55 : 25 + Math.random() * 35;
          setTimeout(type, delay);
        })();
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', run);
      } else {
        run();
      }
    })();
  </script>

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-content">
      <h1 aria-label="From outline to first draft"><span class="type-text">From outline to first draft</span><span class="type-cursor" aria-hidden="true"></span></h1>
      <p class="tagline">Your outline, visible while you write</p>
      <p class="open-source-badge">v{APP_VERSION} · Free & Open Source · AI-free</p>

      <!-- Smart Download CTA (hydrated client-side) -->
      <SmartDownloadButton client:load location="hero" />
    </div>

    <!-- Ember source line: zero-height wrapper sitting between hero-content
         and hero-visual so its embers are anchored at the top edge of the video. -->
    <div class="ember-source" aria-hidden="true">
      <div class="ember-container">
        {embers.map((e) => (
          <span
            class="ember"
            style={`--ember-x:${e.x}%;--ember-size:${e.size}px;--ember-duration:${e.duration}s;--ember-delay:${e.delay}s;--ember-sway:${e.sway}px;--ember-opacity:${e.opacity};--ember-color:${e.color};--ember-glow:${e.glow}px;`}
          />
        ))}
      </div>
    </div>

    <!-- Product visual inside hero — CTA flows directly into screenshot -->
    <div class="hero-visual">
      <video autoplay loop muted playsinline preload="metadata" poster="/hero-poster.jpg" width="804" height="556" aria-label="Kindling scaffolded writing view with scene beats">
        <source src="/demo-2.webm" type="video/webm">
        <source src="/demo-2.mp4" type="video/mp4">
      </video>
    </div>
  </section>

  <!-- Social Proof Bar -->
  <section class="social-proof fade-in-on-scroll">
    <div class="social-proof-container">
      <div class="proof-item">
        <span class="proof-icon">&#9997;</span>
        <span class="proof-text">Trusted by 500+ writers</span>
      </div>
      <div class="proof-divider"></div>
      <div class="proof-item">
        <span class="proof-icon">&#128274;</span>
        <span class="proof-text">MIT Licensed</span>
      </div>
      <div class="proof-divider"></div>
      <div class="proof-item">
        <span class="proof-icon">&#128640;</span>
        <span class="proof-text">Built with Rust & Tauri</span>
      </div>
      <div class="proof-divider"></div>
      <div class="proof-item">
        <span class="proof-icon">&#128187;</span>
        <span class="proof-text">macOS · Windows · Linux</span>
      </div>
    </div>
  </section>

  <!-- Problem Statement -->
  <section class="problem-section fade-in-on-scroll">
    <div class="problem-container">
      <h2>You planned every beat.<br>Then you opened a blank document.</h2>
      <p>Writing apps make you choose: outline <em>or</em> draft. Your beats live in Plottr, your manuscript in Scrivener, your notes in Obsidian. Kindling puts them all in one focused space — so your outline stays visible while you write.</p>
    </div>
  </section>

  <!-- Feature Bento Grid -->
  <section class="features-section">
    <div class="features-header fade-in-on-scroll">
      <h2>Fiction writing software built for outline-driven novelists</h2>
      <p class="features-intro">Stop switching between apps. Kindling brings your planning and drafting into one focused space — where outlines become novels.</p>
    </div>

    <div class="bento-grid">
      <div class="bento-tile bento-tile--large fade-in-on-scroll">
        <div class="bento-label">Core Feature</div>
        <h3>Outline-Aware Drafting</h3>
        <p class="bento-problem">Other apps make you flip between your outline and a blank page.</p>
        <p class="bento-solution">Kindling puts your scene beats right inside your writing space. Click a beat, write into it.</p>
        <Image src={beatWithProse} alt="Kindling editor showing scene beats alongside prose" width={560} loading="eager" class="bento-image" />
      </div>

      <div class="bento-tile fade-in-on-scroll">
        <div class="bento-label">Stay in Flow</div>
        <h3>References Panel</h3>
        <p class="bento-problem">Was it green eyes or blue? What was the tavern called?</p>
        <p class="bento-solution">Characters and locations tagged in your scene auto-surface in a side panel.</p>
        <Image src={referencesPanel} alt="Kindling references panel showing character details" width={560} loading="lazy" class="bento-image" />
      </div>

      <div class="bento-tile fade-in-on-scroll">
        <div class="bento-label">Your Pace</div>
        <h3>Rolling Outline</h3>
        <p class="bento-problem">Not every scene needs the same level of planning.</p>
        <p class="bento-solution">Three planning states — Fixed, Flexible, Undefined — let you add structure at your own pace. <a href="/story-outlining-software/" style="color: var(--ember-orange);">Learn more &rarr;</a></p>
      </div>

      <div class="bento-tile fade-in-on-scroll">
        <div class="bento-label">Your Tools</div>
        <h3>Import & Export</h3>
        <p class="bento-problem">Your outline lives in Plottr. Your manuscript in Word. Your notes in Obsidian.</p>
        <p class="bento-solution">Import from Plottr, yWriter, Obsidian Longform, Scrivener, or Markdown. Export to DOCX, Markdown, Scrivener, or EPUB.</p>
      </div>
    </div>
  </section>

  <!-- v1.2 Spotlight -->
  <section class="spotlight">
    <div class="spotlight-container">
      <div class="fade-in-on-scroll">
        <span class="version-badge">New in v{APP_VERSION}</span>
        <h2>The biggest update yet</h2>
      </div>
      <div class="spotlight-grid">
        <div class="spotlight-feature fade-in-on-scroll">
          <div class="spotlight-icon">🌙</div>
          <div class="spotlight-label">Theme</div>
          <h3>Light Theme</h3>
          <p>Automatic light/dark switching based on your OS preference, with manual override.</p>
        </div>
        <div class="spotlight-feature fade-in-on-scroll">
          <div class="spotlight-icon">📝</div>
          <div class="spotlight-label">Writing</div>
          <h3>Full-Page Prose Editing</h3>
          <p>Draft in a full-page editor — not just beat-by-beat. Toggle between page view and beat view per scene.</p>
        </div>
        <div class="spotlight-feature fade-in-on-scroll">
          <div class="spotlight-icon">🏷️</div>
          <div class="spotlight-label">Organization</div>
          <h3>Custom Fields & Tags</h3>
          <p>Create typed fields on characters and locations. Organize with hierarchical tags and saved filters.</p>
        </div>
        <div class="spotlight-feature fade-in-on-scroll">
          <div class="spotlight-icon">🎬</div>
          <div class="spotlight-label">New Project Type</div>
          <h3>Screenplay Support</h3>
          <p>New screenplay project type with page count estimator, slugline input, and Save the Cat / Hero's Journey templates.</p>
        </div>
        <div class="spotlight-feature fade-in-on-scroll">
          <div class="spotlight-icon">📦</div>
          <div class="spotlight-label">Interoperability</div>
          <h3>Scrivener Import & Export</h3>
          <p>Bidirectional Scrivener workflow. Create new .scriv bundles or update existing ones with a match preview dialog.</p>
        </div>
        <div class="spotlight-feature fade-in-on-scroll">
          <div class="spotlight-icon">🔍</div>
          <div class="spotlight-label">Intelligence</div>
          <h3>Smart Reference Detection</h3>
          <p>Non-AI engine scans your prose for character, location, and item mentions. Suggestions surface automatically.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bottom-cta fade-in-on-scroll">
    <div class="bottom-cta-container">
      <h2>Your outline is ready. Start writing.</h2>
      <SmartDownloadButton client:visible location="bottom" />
    </div>
  </section>
</MarketingLayout>

<style>
  /* Hero */
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 72px 24px 0;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 150%;
    height: 60%;
    background: radial-gradient(ellipse at center top, rgba(232, 90, 27, 0.08) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 760px;
    width: 100%;
  }

  /* ===== Ember source =====
     Zero-height flex item between hero-content and hero-visual. Exists
     purely to position .ember-container so embers rise from the top edge
     of the demo video. */
  .ember-source {
    position: relative;
    width: 100%;
    max-width: 960px;
    height: 0;
    margin-top: 40px; /* mirrors the old hero-visual margin-top — seam stays put */
    pointer-events: none;
  }

  /* ===== Ember particles =====
     Anchored at the ember-source line (bottom: 0) and rise upward. Each .ember
     reads its randomized values from CSS custom properties set inline, so
     one set of keyframes drives N unique trajectories. */
  .ember-container {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;        /* anchored at the ember-source line */
    height: 520px;    /* vertical travel range; .hero's overflow:hidden clips anything escaping */
    pointer-events: none;
    z-index: 2;       /* sits above .hero-visual (z-index: 1) so rising embers stay visible */
  }

  .ember {
    position: absolute;
    bottom: 0;
    left: var(--ember-x);
    width: var(--ember-size);
    height: var(--ember-size);
    background: var(--ember-color, var(--ember-orange));
    border-radius: 50%;
    /* Glow radius scales with size — larger embers are visibly brighter.
       Softer tint (30% not 45%) to reduce overall brightness. */
    box-shadow: 0 0 var(--ember-glow, 8px) 0 color-mix(in srgb, var(--ember-color, var(--ember-orange)) 30%, transparent);
    opacity: 0;
    animation:
      ember-rise var(--ember-duration) linear var(--ember-delay) infinite,
      ember-flicker calc(var(--ember-duration) / 5) ease-in-out var(--ember-delay) infinite alternate;
    will-change: transform, opacity, filter;
  }

  @keyframes ember-rise {
    0%   { transform: translate3d(0, 0, 0) scale(1); opacity: 0; }
    12%  { opacity: var(--ember-opacity); }
    75%  { opacity: var(--ember-opacity); }
    100% { transform: translate3d(var(--ember-sway), -480px, 0) scale(0.3); opacity: 0; }
  }

  /* Gentle brightness waver — dimmer range than before per design feedback. */
  @keyframes ember-flicker {
    from { filter: brightness(0.65); }
    to   { filter: brightness(1.0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .ember-container { display: none; }
  }

  @media (max-width: 768px) {
    /* Thin out the swarm on mobile so it stays atmosphere, not noise. */
    .ember:nth-child(n+13) { display: none; }
  }

  .hero h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(36px, 7vw, 60px);
    font-weight: 600;
    margin-bottom: 10px;
    letter-spacing: -0.02em;
  }

  .tagline {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(20px, 3.5vw, 30px);
    font-weight: 500;
    color: var(--ember-orange);
    margin-bottom: 12px;
  }

  .open-source-badge {
    display: inline-block;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: var(--success);
    background: rgba(45, 156, 107, 0.15);
    border: 1px solid rgba(45, 156, 107, 0.3);
    padding: 5px 14px;
    border-radius: 100px;
    margin-bottom: 24px;
    letter-spacing: 0.02em;
  }

  /* Hero visual — product screenshot/video directly below CTA.
     Spacing above is now owned by the .ember-source element so the seam stays aligned. */
  .hero-visual {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 960px;
    margin-top: 0;
    /* Clip so the bottom edge bleeds into the next section, enticing scroll */
    mask-image: linear-gradient(to bottom, black 70%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 70%, transparent 100%);
  }

  .hero-visual video {
    width: 100%;
    height: auto;
    border-radius: 12px 12px 0 0;
    display: block;
  }

  /* Social Proof Bar */
  .social-proof {
    padding: 32px 24px;
    border-top: 1px solid var(--surface-light);
    border-bottom: 1px solid var(--surface-light);
  }

  .social-proof-container {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .proof-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .proof-icon {
    font-size: 18px;
  }

  .proof-divider {
    width: 1px;
    height: 20px;
    background: var(--surface-light);
  }

  @media (max-width: 600px) {
    .proof-divider { display: none; }
    .social-proof-container { gap: 16px; }
  }

  /* Problem Statement */
  .problem-section {
    padding: 56px 24px;
    text-align: center;
  }

  .problem-container {
    max-width: 700px;
    margin: 0 auto;
  }

  .problem-container h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(24px, 4vw, 36px);
    font-weight: 600;
    margin-bottom: 20px;
    line-height: 1.3;
  }

  .problem-container p {
    font-size: 18px;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* Features Bento Grid */
  .features-section {
    padding: 56px 24px;
    background: var(--surface);
  }

  .features-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .features-header h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(28px, 5vw, 36px);
    font-weight: 600;
    margin-bottom: 12px;
  }

  .features-intro {
    font-size: 18px;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .bento-tile {
    background: var(--deep-charcoal);
    border: 1px solid var(--surface-light);
    border-radius: 16px;
    padding: 28px;
    grid-column: span 2;
    overflow: hidden;
  }

  .bento-tile--large {
    grid-column: span 2;
    grid-row: span 1;
  }

  .bento-label {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ember-orange);
    margin-bottom: 8px;
  }

  .bento-tile h3 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .bento-problem {
    font-size: 15px;
    color: var(--text-secondary);
    font-style: italic;
    margin-bottom: 6px;
  }

  .bento-solution {
    font-size: 15px;
    color: var(--text-primary);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .bento-image {
    width: 100%;
    height: auto;
    border-radius: 8px;
    margin-top: 8px;
  }

  @media (max-width: 768px) {
    .bento-grid {
      grid-template-columns: 1fr;
    }
    .bento-tile,
    .bento-tile--large {
      grid-column: span 1;
    }
  }

  /* v1.2 Spotlight */
  .spotlight {
    padding: 56px 24px;
  }

  .spotlight-container {
    max-width: 1000px;
    margin: 0 auto;
    text-align: center;
  }

  .version-badge {
    display: inline-block;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: var(--ember-orange);
    background: rgba(232, 90, 27, 0.12);
    border: 1px solid rgba(232, 90, 27, 0.3);
    padding: 6px 16px;
    border-radius: 100px;
    margin-bottom: 16px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .spotlight-container h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(28px, 5vw, 36px);
    font-weight: 600;
    margin-bottom: 40px;
  }

  .spotlight-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    text-align: left;
  }

  .spotlight-feature {
    background: var(--surface);
    border: 1px solid var(--surface-light);
    border-radius: 12px;
    padding: 24px;
  }

  .spotlight-icon {
    font-size: 28px;
    margin-bottom: 6px;
    line-height: 1;
  }

  .spotlight-label {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ember-orange);
    margin-bottom: 6px;
  }

  .spotlight-feature h3 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 17px;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .spotlight-feature p {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* Bottom CTA */
  .bottom-cta {
    padding: 72px 24px 80px;
    background: linear-gradient(180deg, var(--surface) 0%, var(--deep-charcoal) 100%);
    text-align: center;
  }

  .bottom-cta-container {
    max-width: 560px;
    margin: 0 auto;
  }

  .bottom-cta h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(28px, 5vw, 36px);
    font-weight: 600;
    margin-bottom: 24px;
  }
</style>

